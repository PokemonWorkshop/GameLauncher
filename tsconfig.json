{
  "compilerOptions": {
    "target": "ES2021",
    "strict": true,
    "allowJs": true,
    "module": "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": "src",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react",
    "paths": {
      "@pages/*": ["pages/*"],
      "@assets/*": ["assets/*"],
      "@ipcMain/*": ["ipc/main/*"],
      "@ipcRenderer/*": ["ipc/renderer/*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["components/hooks/*"],
      "@utils/*": ["utils/*"],
      "@src/*": ["*"],
      "*": ["../node_modules/*"]
    }
  },
  "include": ["src/**/*", "config/**/*", "forge.config.ts"]
}
